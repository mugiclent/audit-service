NODE_ENV=development
PORT=8101

# ── Local dev (docker-compose.local.yml) ──────────────────────────────────────
# Use full URLs pointing directly to the local containers.
# When DATABASE_URL / RABBITMQ_URL are set, DB_PASSWORD / RABBITMQ_USER /
# RABBITMQ_PASSWORD are not required.
DATABASE_URL=postgresql://audit_svc:localpassword@postgres:5432/audit_db
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# ── Production (Infisical at /audit-svc) ──────────────────────────────────────
# Infisical injects these; config/index.ts builds the pgbouncer connection string.
# Remove DATABASE_URL and RABBITMQ_URL when using the production path.
# DB_PASSWORD=
# RABBITMQ_USER=
# RABBITMQ_PASSWORD=
