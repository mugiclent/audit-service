# Docker image — managed by CI/CD pipeline (do not edit manually in production)
DOCKER_USERNAME=ktshonln
IMAGE_TAG=latest

NODE_ENV=development
PORT=8101

# PostgreSQL — password for audit_svc user (host/db fixed: pgbouncer:6432/audit_db)
# Local value: see AUDIT_DB_PASSWORD in ../db/docker-compose.override.yml
DB_PASSWORD=change_me

# RabbitMQ — credentials (host fixed: rabbitmq:5672)
# Local values: see ../rabbitmq/.env.example
RABBITMQ_USER=katisha
RABBITMQ_PASSWORD=change_me

# Direct postgres URL — only needed for migration commands (prisma migrate dev/deploy).
# Bypasses PgBouncer so advisory locks and DDL work correctly.
# Local: postgresql://audit_svc:<DB_PASSWORD>@127.0.0.1:5432/audit_db
# In-container (katisha-net): postgresql://audit_svc:<DB_PASSWORD>@db:5432/audit_db
DIRECT_DATABASE_URL=postgresql://audit_svc:change_me@127.0.0.1:5432/audit_db

# Shadow DB for prisma migrate dev — needs a user with CREATEDB privilege.
# Use the postgres superuser; see POSTGRES_PASSWORD in ../db/docker-compose.override.yml
# SHADOW_DATABASE_URL=postgresql://katisha:change_me@127.0.0.1:5432/postgres
